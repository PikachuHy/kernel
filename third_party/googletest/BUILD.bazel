load("@rules_cc//cc:defs.bzl", "cc_import", "cc_library")

cc_import(
    name = "gtest_lib",
    static_library = "lib/libgtest.a",
    alwayslink = True,
    visibility = ["//visibility:private"],
)

cc_import(
    name = "gtest_main_lib",
    static_library = "lib/libgtest_main.a",
    alwayslink = True,
    visibility = ["//visibility:private"],
)

cc_library(
    name = "gtest",
    hdrs = glob(["include/gtest/**/*.h"]),
    includes = ["include"],
    deps = [":gtest_lib"],
    linkopts = ["-lc++"],
    visibility = ["//visibility:public"],
)

cc_library(
    name = "gtest_main",
    deps = [
        ":gtest",
        ":gtest_main_lib",
    ],
    linkopts = ["-lc++"],
    visibility = ["//visibility:public"],
)
